# For localhost access (development on same machine)
REACT_APP_API_URL=http://localhost:5000/api

# For network access (other devices on same WiFi)
# Replace YOUR_LOCAL_IP with your machine's IP address (e.g., 192.168.1.100)
# REACT_APP_API_URL=http://YOUR_LOCAL_IP:5000/api

# API timeout in milliseconds
REACT_APP_API_TIMEOUT=30000
